{
    "cli": {
        "version": ">= 18.0.3"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8000"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            }
        },
        "share": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://REPLACE_WITH_YOUR_BACKEND_URL"
            }
        },
        "production": {
            "android": {
                "buildType": "aab"
            }
        }
    }
}
